# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string
# Railway injects this automatically when the PostgreSQL plugin is attached.
# Local example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use /broadcast
# Leave empty to disable the broadcast command entirely.
# Example: BROADCAST_ADMIN_IDS=123456789,987654321
BROADCAST_ADMIN_IDS=

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# Timezone string for log timestamps  (default: UTC)
TZ=UTC

# Maximum concurrent broadcast tasks  (default: 2)
MAX_CONCURRENT_TASKS=2

# Drop updates that arrived while the bot was offline  (default: true)
# Set to false to process pending messages after restart.
START_FROM_LATEST=true
